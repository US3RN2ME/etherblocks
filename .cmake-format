line_width: 128
tab_size: 3
separate_ctrl_name_with_space: false
separate_fn_name_with_space: false
dangle_parens: false
command_case: lower
keyword_case: upper
max_pargs_hwrap: 6
max_subgroups_hwrap: 2
max_rows_cmdline: 2

autosort: true
enable_sort: true

markup:
  enable_markup: true

encode:
  emit_byteorder_mark: false